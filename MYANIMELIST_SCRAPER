# ─── Scraper ──────────────────────────────────────────────────────────────────
def scrape_season_tv(year, season, progress_cb=None):
    """
    Scrape only TV (New) anime from MAL seasonal page.
    MAL separates sections by div.js-seasonal-anime-list with data-key.
    TV New = list-key-1, which contains the header 'TV New'.
    We also pass ?type=tv to the URL to pre-filter server-side.
    """
    url = f"https://myanimelist.net/anime/season/{year}/{season}"
    params = {"type": "tv"}
    try:
        resp = requests.get(url, headers=HEADERS, params=params, timeout=15)
        resp.raise_for_status()
    except Exception as e:
        return []

    soup = BeautifulSoup(resp.text, "html.parser")

    # Find the TV New section specifically
    # It is inside: div.seasonal-anime-list.js-seasonal-anime-list-key-1
    tv_section = soup.select_one(
        "div.seasonal-anime-list.js-seasonal-anime-list-key-1"
    )

    if tv_section:
        cards = tv_section.select(
            "div.js-seasonal-anime.seasonal-anime.js-anime-type-1"
        )
    else:
        # Fallback: grab all type-1 cards from full page
        cards = soup.select(
            "div.js-seasonal-anime.seasonal-anime.js-anime-type-1"
        )

    # Extra safety: exclude kids section if needed
    # (kids cards have class 'kids js-kids' - we keep them unless excluded)
    results = []
    total = len(cards)

    for i, card in enumerate(cards):
        # ── Title ────────────────────────────────────────────────────────────
        title_tag = card.select_one("h2.h2_anime_title a, a.link-title")
        title = title_tag.get_text(strip=True) if title_tag else "N/A"

        sub_tag = card.select_one("h3.h3_anime_subtitle")
        subtitle = sub_tag.get_text(strip=True) if sub_tag else ""

        mal_link = title_tag.get("href", "") if title_tag else ""
        if mal_link and not mal_link.startswith("http"):
            mal_link = "https://myanimelist.net" + mal_link

        # ── Release date ─────────────────────────────────────────────────────
        date_tag = card.select_one("span.js-startdate")
        raw_date = date_tag.get_text(strip=True) if date_tag else ""
        release_date = ""
        if raw_date:
            try:
                dt = datetime.strptime(raw_date, "%Y%m%d")
                release_date = dt.strftime("%b %d, %Y")
            except Exception:
                pass
        if not release_date:
            info_span = card.select_one("div.info span.item")
            release_date = info_span.get_text(strip=True) if info_span else "N/A"

        # ── Genres ───────────────────────────────────────────────────────────
        genres = [
            g.get_text(strip=True)
            for g in card.select("div.genres-inner span.genre a")
        ]

        # ── Cover image ──────────────────────────────────────────────────────
        img_tag = card.select_one("div.image img")
        img_url = ""
        if img_tag:
            img_url = (
                img_tag.get("data-src")
                or img_tag.get("src", "")
            )
            if not img_url:
                srcset = img_tag.get("data-srcset") or img_tag.get("srcset", "")
                if srcset:
                    img_url = srcset.split(",")[0].strip().split(" ")[0]

        # ── Score & Members ──────────────────────────────────────────────────
        score_tag  = card.select_one("span.js-score")
        score      = score_tag.get_text(strip=True) if score_tag else "N/A"
        mem_tag    = card.select_one("span.js-members")
        members    = mem_tag.get_text(strip=True) if mem_tag else "N/A"

        # ── Properties: Studio, Source, Themes, Demographics ─────────────────
        studio = source = ""
        themes = []
        demographics = []

        for prop in card.select("div.property"):
            cap = prop.select_one("span.caption")
            if not cap:
                continue
            cap_text = cap.get_text(strip=True)
            if "Studio" in cap_text:
                items = prop.select("span.item a")
                studio = ", ".join(a.get_text(strip=True) for a in items)
                if not studio:
                    it = prop.select_one("span.item")
                    studio = it.get_text(strip=True) if it else ""
            elif "Source" in cap_text:
                it = prop.select_one("span.item")
                source = it.get_text(strip=True) if it else ""
            elif "Theme" in cap_text:
                themes = [a.get_text(strip=True) for a in prop.select("span.item a")]
            elif "Demographic" in cap_text:
                demographics = [a.get_text(strip=True) for a in prop.select("span.item a")]

        # ── Episodes info ─────────────────────────────────────────────────────
        info_tag = card.select_one("div.info")
        eps_info = ""
        if info_tag:
            eps_info = " | ".join(
                s.get_text(strip=True)
                for s in info_tag.select("span.item")
                if s.get_text(strip=True)
            )

        # ── Synopsis ──────────────────────────────────────────────────────────
        syn_tag  = card.select_one("p.preline")
        synopsis = syn_tag.get_text(strip=True) if syn_tag else ""

        results.append({
            "title":        title,
            "subtitle":     subtitle,
            "release_date": release_date,
            "genres":       genres,
            "themes":       themes,
            "demographics": demographics,
            "score":        score,
            "members":      members,
            "studio":       studio,
            "source":       source,
            "synopsis":     synopsis,
            "img_url":      img_url,
            "mal_link":     mal_link,
            "eps_info":     eps_info,
            "type":         "TV",
        })

        if progress_cb:
            progress_cb(i + 1, total)

    return results


# ─── Image helpers ────────────────────────────────────────────────────────────
def get_cover(url, size):
    key = (url, size)
    if key in IMG_CACHE:
        return IMG_CACHE[key]
    if not url:
        return None
    try:
        resp = requests.get(url, headers=HEADERS, timeout=8)
        img  = Image.open(io.BytesIO(resp.content)).convert("RGB")
        img  = img.resize(size, Image.LANCZOS)
        photo = ImageTk.PhotoImage(img)
        IMG_CACHE[key] = photo
        return photo
    except Exception:
        return None


def make_placeholder(size):
    img  = Image.new("RGB", size, color="#12152A")
    draw = ImageDraw.Draw(img)
    draw.rectangle([0, 0, size[0]-1, size[1]-1], outline="#2A2E55", width=2)
    cx, cy = size[0]//2, size[1]//2
    draw.text((cx - 4, cy - 6), "?", fill="#3A3E65")
    return ImageTk.PhotoImage(img)


def make_tag(parent, text, bg=None, fg=None):
    return tk.Label(
        parent, text=text,
        bg=bg or P["tag_bg"], fg=fg or P["accent"],
        font=("Segoe UI", 7, "bold"),
        padx=5, pady=2, relief="flat",
    )


# ─── Grid Card ────────────────────────────────────────────────────────────────
class GridCard(tk.Frame):
    def __init__(self, master, data, **kwargs):
        super().__init__(
            master, bg=P["bg_card"], relief="flat", bd=0,
            highlightthickness=1, highlightbackground=P["border"],
            cursor="hand2", **kwargs,
        )
        self.data = data
        self._ph  = make_placeholder(COVER_GRID_SIZE)
        self._build()
        self._bind_hover(self)

    def _build(self):
        d = self.data

        # Cover
        self.cover_lbl = tk.Label(
            self, image=self._ph, bg=P["bg_card"],
            relief="flat", bd=0,
        )
        self.cover_lbl.pack(fill="x")

        # TV badge overlay
        badge_row = tk.Frame(self, bg=P["bg_card"])
        badge_row.pack(fill="x", padx=8, pady=(4, 0))
        tk.Label(
            badge_row, text="TV NEW",
            bg="#7C6FFF", fg=P["white"],
            font=("Segoe UI", 7, "bold"), padx=5, pady=1,
        ).pack(side="left")

        body = tk.Frame(self, bg=P["bg_card"])
        body.pack(fill="both", expand=True, padx=9, pady=(5, 9))

        # Title
        tk.Label(
            body, text=d["title"],
            bg=P["bg_card"], fg=P["text_h"],
            font=("Segoe UI", 9, "bold"),
            wraplength=148, justify="left", anchor="w",
        ).pack(anchor="w")

        if d.get("subtitle"):
            tk.Label(
                body, text=d["subtitle"],
                bg=P["bg_card"], fg=P["text_m"],
                font=("Segoe UI", 7, "italic"),
                wraplength=148, justify="left",
            ).pack(anchor="w", pady=(0, 2))

        # Score + members
        r1 = tk.Frame(body, bg=P["bg_card"])
        r1.pack(anchor="w", pady=(4, 0))
        score = d.get("score", "N/A")
        sc    = P["gold"] if score not in ("N/A", "0", "") else P["text_m"]
        tk.Label(
            r1, text="* " + (score if score not in ("N/A", "0", "") else "N/A"),
            bg=P["bg_card"], fg=sc,
            font=("Segoe UI", 9, "bold"),
        ).pack(side="left")
        if d.get("members") and d["members"] != "N/A":
            tk.Label(
                r1, text="  " + d["members"] + " users",
                bg=P["bg_card"], fg=P["text_m"],
                font=("Segoe UI", 7),
            ).pack(side="left")

        # Date
        if d.get("release_date"):
            tk.Label(
                body, text=d["release_date"],
                bg=P["bg_card"], fg=P["accent3"],
                font=("Segoe UI", 8),
            ).pack(anchor="w", pady=(2, 0))

        # Eps
        if d.get("eps_info"):
            tk.Label(
                body, text=d["eps_info"],
                bg=P["bg_card"], fg=P["text_p"],
                font=("Segoe UI", 7),
            ).pack(anchor="w")

        # Studio
        if d.get("studio"):
            tk.Label(
                body, text=d["studio"],
                bg=P["bg_card"], fg=P["blue_light"],
                font=("Segoe UI", 7),
            ).pack(anchor="w", pady=(1, 0))

        # Source
        if d.get("source"):
            tk.Label(
                body, text="Src: " + d["source"],
                bg=P["bg_card"], fg=P["text_m"],
                font=("Segoe UI", 7),
            ).pack(anchor="w")

        # Genre tags
        tags = d.get("genres", [])[:4]
        if tags:
            gf = tk.Frame(body, bg=P["bg_card"])
            gf.pack(anchor="w", pady=(5, 2))
            for g in tags:
                make_tag(gf, g).pack(side="left", padx=1)

        # Themes
        th = d.get("themes", [])[:2]
        if th:
            tf = tk.Frame(body, bg=P["bg_card"])
            tf.pack(anchor="w", pady=(1, 0))
            for t in th:
                make_tag(tf, t, bg="#1A2535", fg="#5EC8FA").pack(side="left", padx=1)

        # Demographics
        dm = d.get("demographics", [])
        if dm:
            df = tk.Frame(body, bg=P["bg_card"])
            df.pack(anchor="w", pady=(1, 0))
            for de in dm:
                make_tag(df, de, bg="#1F1A35", fg="#C47EFF").pack(side="left", padx=1)

        # Synopsis preview
        syn = d.get("synopsis", "")
        if syn:
            prev = syn[:110] + ("..." if len(syn) > 110 else "")
            tk.Label(
                body, text=prev,
                bg=P["bg_card"], fg=P["text_m"],
                font=("Segoe UI", 7),
                wraplength=150, justify="left",
            ).pack(anchor="w", pady=(5, 0))

        # MAL link
        if d.get("mal_link"):
            lnk = tk.Label(
                body, text="Open on MAL ->",
                bg=P["bg_card"], fg=P["accent"],
                font=("Segoe UI", 7, "underline"), cursor="hand2",
            )
            lnk.pack(anchor="w", pady=(6, 0))
            lnk.bind("<Button-1>", lambda e: webbrowser.open(d["mal_link"]))

    def _bind_hover(self, w):
        if not (isinstance(w, tk.Label) and w.cget("cursor") == "hand2" and w != self):
            w.bind("<Enter>", self._enter)
            w.bind("<Leave>", self._leave)
        for c in w.winfo_children():
            self._bind_hover(c)

    def _enter(self, e=None):
        self._recolor(P["bg_hover"])
        self.config(highlightbackground=P["accent"])

    def _leave(self, e=None):
        self._recolor(P["bg_card"])
        self.config(highlightbackground=P["border"])

    def _recolor(self, col):
        def r(w):
            try:
                if isinstance(w, (tk.Frame, tk.Label)):
                    w.config(bg=col)
            except Exception:
                pass
            for c in w.winfo_children():
                r(c)
        r(self)

    def set_cover(self, photo):
        self.cover_lbl.config(image=photo)
        self.cover_lbl.image = photo


