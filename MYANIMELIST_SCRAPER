    # ── Helpers ───────────────────────────────────────────────────────────────
    def _tick_clock(self):
        self.clock_lbl.configure(text=datetime.now().strftime("%A, %d %b %Y  %H:%M:%S"))
        self.after(1000, self._tick_clock)

    def _pick(self, s):
        self.season_var.set(s)
        col = SEASON_ACCENT.get(s, P["accent"])
        for k, b in self._sbtns.items():
            if k == s:
                b.configure(fg_color=col, text_color=P["white"], border_color=col)
            else:
                b.configure(fg_color=P["bg_deep"], text_color=P["text_p"],
                            border_color=P["border2"])

    def _set_view(self, mode):
        self._view = mode
        self._gbtn.configure(fg_color=P["accent"] if mode=="grid" else P["bg_panel"])
        self._lbtn.configure(fg_color=P["accent"] if mode=="list" else P["bg_panel"])
        self._rebuild()

    def _on_resize(self, e=None):
        self.canvas.itemconfig(self._win, width=e.width)
        self._rebuild()

    # ── Fetch ─────────────────────────────────────────────────────────────────
    def _start_fetch(self):
        if self._loading:
            return
        y = self.year_var.get().strip()
        if not y.isdigit() or not (1917 <= int(y) <= 2030):
            messagebox.showerror("Invalid Year", "Enter a valid year (1917-2030).")
            return
        season = self.season_var.get()
        year   = int(y)

        self._loading = True
        self.fetch_btn.configure(state="disabled", text="Fetching...")
        self.pbar.set(0)
        self.status_lbl.configure(text=f"Fetching {SEASON_LABELS[season]} {year} TV...")
        self._clear()

        def worker():
            def pcb(done, total):
                self.after(0, lambda: self.pbar.set(done / max(total, 1)))
                self.after(0, lambda: self.status_lbl.configure(
                    text=f"Parsed {done}/{total} TV entries..."))
            data = scrape_season_tv(year, season, pcb)
            self.after(0, lambda: self._done(data, year, season))

        threading.Thread(target=worker, daemon=True).start()

    def _done(self, data, year, season):
        self._loading = False
        self.fetch_btn.configure(state="normal", text="Fetch TV Anime")
        self.pbar.set(1)

        if not data:
            self.status_lbl.configure(text="No TV data. MAL may be rate-limiting.")
            messagebox.showwarning("No Results",
                "No TV anime found.\n\nMAL may be blocking — try again in a moment.")
            return

        self._results = data
        self._refresh_genres()
        self._filter()

        scores = [float(d["score"]) for d in data if d.get("score") not in ("N/A","0","")]
        avg    = round(sum(scores)/len(scores), 2) if scores else "N/A"
        self.stats_lbl.configure(
            text=f"TV New: {len(data)}\nAvg Score: {avg}\n{SEASON_LABELS[season]} {year}"
        )
        self.status_lbl.configure(text=f"Done - {len(data)} TV anime loaded")

    # ── Filter & Sort ─────────────────────────────────────────────────────────
    def _refresh_genres(self):
        all_g = sorted(set(g for d in self._results for g in d.get("genres", [])))
        self.genre_var.set("All")
        self.genre_menu.configure(values=["All"] + all_g)

    def _filter(self):
        q  = self.search_var.get().strip().lower()
        gf = self.genre_var.get()
        out = []
        for d in self._results:
            if q:
                hay = (
                    d.get("title","").lower()
                    + " ".join(d.get("genres",[])).lower()
                    + d.get("studio","").lower()
                    + d.get("synopsis","").lower()
                )
                if q not in hay:
                    continue
            if gf != "All" and gf not in d.get("genres",[]):
                continue
            out.append(d)

        srt = self.sort_var.get()
        if srt == "Score":
            out.sort(key=lambda d: float(d["score"]) if d.get("score") not in ("N/A","0","") else 0, reverse=True)
        elif srt == "Date":
            def pd(s):
                for fmt in ("%b %d, %Y", "%b %Y"):
                    try:
                        return datetime.strptime(s, fmt)
                    except Exception:
                        pass
                return datetime.min
            out.sort(key=lambda d: pd(d.get("release_date","")))
        elif srt == "Members":
            def pm(s):
                s = s.replace("K","000").replace(".","").replace(",","")
                try:
                    return int(s)
                except Exception:
                    return 0
            out.sort(key=lambda d: pm(d.get("members","0")), reverse=True)
        else:
            out.sort(key=lambda d: d.get("title","").lower())

        self._filtered = out
        self.count_lbl.configure(text=f"{len(out)} TV results")
        self._rebuild()

    # ── Render ────────────────────────────────────────────────────────────────
    def _clear(self):
        for w in self.cf.winfo_children():
            w.destroy()
        self._cards.clear()

    def _rebuild(self):
        self._clear()
        if not self._filtered:
            tk.Label(
                self.cf, text="No TV anime results found.",
                bg=P["bg_deep"], fg=P["text_m"],
                font=("Segoe UI", 14),
            ).pack(pady=80)
            return
        if self._view == "grid":
            self._build_grid()
        else:
            self._build_list()

    def _build_grid(self):
        cw    = self.canvas.winfo_width() or 1080
        CARDW = 188
        PAD   = 14
        OUTER = 16
        cols  = max(1, (cw - OUTER*2 + PAD) // (CARDW + PAD))

        wrap = tk.Frame(self.cf, bg=P["bg_deep"])
        wrap.pack(fill="both", expand=True, padx=OUTER, pady=OUTER)

        for i, data in enumerate(self._filtered):
            card = GridCard(wrap, data)
            card.grid(row=i//cols, column=i%cols,
                      padx=PAD//2, pady=PAD//2, sticky="n")
            self._cards.append(card)

        self._lazy_covers(self._cards, self._filtered, COVER_GRID_SIZE)

    def _build_list(self):
        wrap = tk.Frame(self.cf, bg=P["bg_deep"])
        wrap.pack(fill="both", expand=True, padx=16, pady=14)

        for i, data in enumerate(self._filtered):
            row = ListRow(wrap, data, is_odd=(i%2==1))
            row.pack(fill="x", pady=5)
            self._cards.append(row)

        self._lazy_covers(self._cards, self._filtered, COVER_LIST_SIZE)

    def _lazy_covers(self, widgets, data_list, size):
        pairs = list(zip(widgets, data_list))
        def load():
            for w, d in pairs:
                url = d.get("img_url","")
                if not url:
                    continue
                photo = get_cover(url, size)
                if photo:
                    try:
                        w.after(0, lambda ww=w, p=photo: ww.set_cover(p))
                    except Exception:
                        pass
                time.sleep(0.025)
        threading.Thread(target=load, daemon=True).start()

    # ── Export ────────────────────────────────────────────────────────────────
    def _export(self):
        if not self._filtered:
            messagebox.showwarning("No Data", "Nothing to export.")
            return
        fn = f"mal_tv_{self.year_var.get()}_{self.season_var.get()}.csv"
        fields = ["title","subtitle","release_date","genres","themes",
                  "demographics","score","members","studio","source",
                  "synopsis","eps_info","mal_link","img_url","type"]
        with open(fn, "w", newline="", encoding="utf-8") as f:
            w = csv.DictWriter(f, fieldnames=fields, extrasaction="ignore")
            w.writeheader()
            for row in self._filtered:
                r2 = dict(row)
                for k in ("genres","themes","demographics"):
                    r2[k] = ", ".join(r2.get(k,[]))
                w.writerow(r2)
        messagebox.showinfo("Exported", f"Saved:\n{os.path.abspath(fn)}")


